local dragging, dragInput, dragStart, startPos

local function update(input)
	local delta = input.Position - dragStart
	PanelWindow.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

PanelWindow.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = PanelWindow.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then dragging = false end
		end)
	end
end)

PanelWindow.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then update(input) end
end)

local function getGradients(p1)
	local t = {}
	for i, v in ipairs(p1:GetDescendants()) do
		if v:IsA("UIGradient") then table.insert(t, { obj = v, original = v.Transparency }) end
	end
	return t
end

local function getAllVisuals(p1)
	local t = {}
	for i, v in ipairs(p1:GetDescendants()) do
		if v:IsA("UIStroke") then table.insert(t, { prop = "Transparency", obj = v }) continue end
		if v:IsA("TextLabel") or v:IsA("TextButton") then
			table.insert(t, { prop = "TextTransparency", obj = v })
			if v.BackgroundTransparency < 1 then table.insert(t, { prop = "BackgroundTransparency", obj = v }) end
			continue
		end
		if v:IsA("ImageLabel") or v:IsA("ImageButton") then
			table.insert(t, { prop = "ImageTransparency", obj = v })
			if v.BackgroundTransparency < 1 then table.insert(t, { prop = "BackgroundTransparency", obj = v }) end
			continue
		end
		if v:IsA("Frame") and v.BackgroundTransparency < 1 then table.insert(t, { prop = "BackgroundTransparency", obj = v }) end
	end
	if p1:IsA("Frame") and p1.BackgroundTransparency < 1 then table.insert(t, { prop = "BackgroundTransparency", obj = p1 }) end
	return t
end

local function showAnnouncement(p1, p2, p3, p4, p5)
	local v2 = NotificationFrame:Clone()
	v2.ZIndex = 100

	local listLayout = v2:FindFirstChildOfClass("UIListLayout")
	if listLayout then
		listLayout.Padding = UDim.new(0, 4)
	end
	local framePadding = v2:FindFirstChildOfClass("UIPadding")
	if framePadding then
		framePadding.PaddingLeft = UDim.new(0, 6)
	end

	local Avatar = v2:FindFirstChild("Avatar")
	if Avatar and Avatar:IsA("ImageLabel") then
		Avatar.ZIndex = 101
		
		Avatar.Size = UDim2.new(0.8, 0, 0.8, 0)
		Avatar.SizeConstraint = Enum.SizeConstraint.RelativeYY
		
		if p3 then
			local ok, result = pcall(function()
				return Players:GetUserThumbnailAsync(p3, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
			end)
			if ok and result then Avatar.Image = result end
		end
	end

	local Text = v2:FindFirstChild("Text")
	if Text then
		Text.ZIndex = 101
		Text.RichText = true
		
		Text.Size = UDim2.new(1, -50, 1, 0) 
		
		local v3 = p2 or "Admin"
		local v4 = p4 and v3 .. "\238\128\128" or v3
		local v5 = if p5 then rolesTable[p5] else nil

		if v5 then
			Text.Text = string.format("<font color=\"%s\">%s</font> <font color=\"rgb(85,170,255)\"><b>%s</b></font> : %s", v5.Color, v5.Prefix, v4, p1)
		else
			Text.Text = "<font color=\"rgb(85,170,255)\"><b>" .. v4 .. "</b></font> : " .. p1
		end
	end

	local v6 = getAllVisuals(v2)
	local v7 = getGradients(v2)
	local t2 = {}

	for i, v in ipairs(v6) do
		t2[i] = v.obj[v.prop]
		v.obj[v.prop] = 1
	end

	local v8 = NumberSequence.new(1)
	for i, v in ipairs(v7) do v.obj.Transparency = v8 end

	v2.Parent = MainFrame

	local Sound = Instance.new("Sound")
	Sound.SoundId = "rbxassetid://98797174600699"
	Sound.Volume = 0.4
	Sound.Parent = PlayerGui
	Sound:Play()
	Debris:AddItem(Sound, 5)

	local v9 = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	for i, v in ipairs(v6) do TweenService:Create(v.obj, v9, { [v.prop] = t2[i] }):Play() end
	for i, v in ipairs(v7) do v.obj.Transparency = v.original end

	task.delay(10, function()
		local v1_tween = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
		for i, v in ipairs(v6) do TweenService:Create(v.obj, v1_tween, { [v.prop] = 1 }):Play() end
		for i, v in ipairs(v7) do v.obj.Transparency = v8 end
		task.delay(0.5, function()
			if v2 then v2:Destroy() end
		end)
	end)
end

